---
import { Phone, Mail, MapPin, Clock, ArrowRight } from "lucide-react";
import Container from "@/components/ui/Container.astro";
import { siteConfig } from "@/config/site";
import { businessConfig } from "@/config/business";
import { footerGroups } from "@/config/navigation";

const currentYear = new Date().getFullYear();
---

<footer class="relative border-t border-border bg-background">
  <Container>
    <div class="grid gap-10 py-16 md:grid-cols-2 lg:grid-cols-4">
      {/* Brand column */}
      <div class="lg:col-span-1">
        <a href="#top" class="inline-flex items-center" aria-label={siteConfig.name}>
          <img
            src="/images/logo.webp"
            alt={siteConfig.name}
            width="180"
            height="60"
            class="h-14 w-auto"
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="mt-4 text-sm leading-relaxed text-foreground-light">
          Fort Worth's third-generation roofing contractor. Re-roofing,
          replacement, and new installs across Tarrant, Parker, Palo Pinto,
          Johnson, and Wise Counties since 1996, backed by 90 years of family
          trade.
        </p>

        <a
          href="#contact"
          class="mt-6 inline-flex items-center gap-2 rounded-lg bg-primary-600 px-5 py-2.5 text-sm font-semibold text-white transition-all hover:-translate-y-0.5 hover:bg-primary-500"
        >
          Get a Free Quote
          <ArrowRight className="h-4 w-4" />
        </a>
      </div>

      {/* Nav groups */}
      {
        footerGroups.map((group) => (
          <div>
            <h3 class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted">
              {group.title}
            </h3>
            <ul class="space-y-3">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-foreground-light transition-colors hover:text-primary-300"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      {/* Contact column */}
      <div>
        <h3
          class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted"
        >
          Contact
        </h3>
        <ul class="space-y-4">
          <li>
            <a
              href={`tel:${businessConfig.phoneRaw}`}
              class="flex items-start gap-2.5 text-sm text-foreground-light transition-colors hover:text-primary-300"
            >
              <Phone className="mt-0.5 h-4 w-4 shrink-0 text-primary-300" />
              <span class="font-semibold text-white">
                {businessConfig.phone}
              </span>
            </a>
          </li>
          <li>
            <a
              href={`mailto:${businessConfig.email}`}
              class="flex items-start gap-2.5 text-sm text-foreground-light transition-colors hover:text-primary-300"
            >
              <Mail className="mt-0.5 h-4 w-4 shrink-0 text-primary-300" />
              <span>{businessConfig.email}</span>
            </a>
          </li>
          <li>
            <span
              class="flex items-start gap-2.5 text-sm text-foreground-light"
            >
              <MapPin className="mt-0.5 h-4 w-4 shrink-0 text-primary-300" />
              <span>
                {businessConfig.address.street}<br />
                {businessConfig.address.city}, {businessConfig.address.state}{" "}
                {businessConfig.address.zip}
              </span>
            </span>
          </li>
          <li>
            <span
              class="flex items-start gap-2.5 text-sm text-foreground-light"
            >
              <Clock className="mt-0.5 h-4 w-4 shrink-0 text-primary-300" />
              <span>
                Mon–Sat: 8 AM – 5 PM<br />
                <span class="text-muted">24/7 Emergency Response</span>
              </span>
            </span>
          </li>
        </ul>
      </div>
    </div>

    {/* Service areas strip */}
    {
      businessConfig.serviceAreas.length > 0 && (
        <div class="border-t border-border py-6">
          <p class="text-xs text-muted">
            <span class="font-semibold uppercase tracking-wider text-foreground-light">
              Service Areas:
            </span>{" "}
            {businessConfig.serviceAreas.join(" · ")}
          </p>
        </div>
      )
    }

    {/* Bottom bar */}
    <div
      class="flex flex-col items-center justify-between gap-3 border-t border-border py-6 text-xs text-muted md:flex-row"
    >
      <p>
        &copy; {currentYear} {siteConfig.name}. All rights reserved.
      </p>
      <p>
        Family-owned. Licensed & insured. Texas-built since 1936.
      </p>
    </div>
  </Container>
</footer>
