---
import { ChevronRight, ArrowRight, Phone } from "lucide-react";
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import ImageSlot from "@/components/ui/ImageSlot.astro";
import { cn } from "@/lib/utils";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  heading: string;
  subtitle?: string;
  imageKey: string;
  breadcrumbs?: BreadcrumbItem[];
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  class?: string;
}

const {
  heading,
  subtitle,
  imageKey,
  breadcrumbs,
  primaryCta,
  secondaryCta,
  class: className,
} = Astro.props as Props;
---

<section
  class={cn(
    "relative flex items-center pt-20",
    "min-h-[320px] md:min-h-[380px]",
    className,
  )}
>
  {/* Background */}
  <ImageSlot
    imageKey={imageKey}
    fill
    priority
    class="absolute inset-0 z-0"
    overlayClassName="bg-gradient-to-r from-foreground/80 to-foreground/60"
    sizes="100vw"
  />

  {/* Content */}
  <Container class="relative z-10 py-16 md:py-20">
    {
      breadcrumbs && breadcrumbs.length > 0 && (
        <nav class="mb-4 flex items-center gap-1.5 text-sm text-white/60">
          {breadcrumbs.map((crumb, i) => (
            <span class="flex items-center gap-1.5">
              {i > 0 && <ChevronRight className="h-3.5 w-3.5" />}
              {crumb.href ? (
                <a
                  href={crumb.href}
                  class="transition-colors hover:text-white"
                >
                  {crumb.label}
                </a>
              ) : (
                <span class="text-white">{crumb.label}</span>
              )}
            </span>
          ))}
        </nav>
      )
    }

    <h1
      class="max-w-3xl text-3xl font-bold text-white md:text-4xl lg:text-5xl"
    >
      {heading}
    </h1>

    {
      subtitle && (
        <p class="mt-4 max-w-xl text-lg text-white/80">{subtitle}</p>
      )
    }

    {
      (primaryCta || secondaryCta) && (
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          {primaryCta && (
            <Button href={primaryCta.href} size="lg">
              {primaryCta.label}
              <ArrowRight slot="icon" className="h-5 w-5" />
            </Button>
          )}
          {secondaryCta && (
            <Button
              href={secondaryCta.href}
              variant="outline"
              size="lg"
              class="border-white text-white hover:bg-white hover:text-foreground"
            >
              {secondaryCta.label}
              <Phone slot="icon" className="h-5 w-5" />
            </Button>
          )}
        </div>
      )
    }
  </Container>
</section>
