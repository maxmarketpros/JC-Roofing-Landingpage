---
import { ArrowRight, Phone } from "lucide-react";
import Container from "@/components/ui/Container.astro";
import { businessConfig } from "@/config/business";

interface Props {
  eyebrow?: string;
  /** H1 text. Should always include focus keyword + "Fort Worth, TX". */
  heading: string;
  subtitle?: string;
  /** Root-relative path to the background image, e.g. /images/metal-country-home.webp */
  image: string;
  imageAlt?: string;
  /** Primary CTA href; defaults to /contact */
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  eyebrow,
  heading,
  subtitle,
  image,
  imageAlt = "",
  ctaHref = "/contact",
  ctaLabel = "Get My Free Quote",
} = Astro.props as Props;
---

<section class="relative isolate overflow-hidden">
  {/* Background image */}
  <img
    src={image}
    alt={imageAlt}
    width="1920"
    height="1080"
    loading="eager"
    fetchpriority="high"
    decoding="async"
    class="absolute inset-0 -z-20 h-full w-full object-cover"
  />
  {/* Gradient overlays for legibility */}
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-b from-black/70 via-black/55 to-black/85"
  >
  </div>
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-r from-black/65 via-transparent to-transparent"
  >
  </div>

  <Container>
    <div class="flex min-h-[72vh] flex-col justify-center py-28 md:min-h-[68vh] md:py-32 lg:py-36">
      <div class="max-w-3xl">
        {
          eyebrow && (
            <span class="inline-flex items-center gap-2 rounded-full border border-primary-400/30 bg-primary-600/15 px-4 py-1.5 text-xs font-bold uppercase tracking-[0.2em] text-primary-100">
              {eyebrow}
            </span>
          )
        }
        <h1
          class="mt-5 text-balance text-4xl font-extrabold leading-tight text-white sm:text-5xl md:text-6xl"
        >
          {heading}
        </h1>
        {
          subtitle && (
            <p class="mt-6 max-w-2xl text-lg leading-relaxed text-foreground-light md:text-xl">
              {subtitle}
            </p>
          )
        }

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={ctaHref}
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-primary-600 px-7 py-4 text-base font-semibold text-white shadow-glow transition-all hover:-translate-y-0.5 hover:bg-primary-500"
          >
            {ctaLabel}
            <ArrowRight className="h-5 w-5" />
          </a>
          <a
            href={`tel:${businessConfig.phoneRaw}`}
            class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-white/30 bg-white/5 px-7 py-4 text-base font-semibold text-white backdrop-blur-sm transition-all hover:-translate-y-0.5 hover:border-white hover:bg-white/10"
          >
            <Phone className="h-5 w-5" />
            {businessConfig.phone}
          </a>
        </div>
      </div>
    </div>
  </Container>
</section>
