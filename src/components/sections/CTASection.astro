---
import { ArrowRight, Phone } from "lucide-react";
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import { cn } from "@/lib/utils";

interface Props {
  heading: string;
  text?: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  class?: string;
}

const {
  heading,
  text,
  primaryCta,
  secondaryCta,
  class: className,
} = Astro.props as Props;
---

<section class={cn("bg-primary-600 section-padding", className)}>
  <Container class="text-center">
    <h2 class="mx-auto max-w-2xl text-3xl font-bold text-white md:text-4xl">
      {heading}
    </h2>
    {
      text && (
        <p class="mx-auto mt-4 max-w-xl text-lg text-white/95">{text}</p>
      )
    }
    <div
      class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row"
    >
      <Button
        href={primaryCta.href}
        variant="secondary"
        size="lg"
        class="bg-white text-primary-600 hover:bg-white/90 hover:text-primary-700"
      >
        {primaryCta.label}
        <ArrowRight slot="icon" className="h-5 w-5" />
      </Button>
      {
        secondaryCta && (
          <Button
            href={secondaryCta.href}
            variant="outline"
            size="lg"
            class="border-white text-white hover:bg-white hover:text-primary-600"
          >
            {secondaryCta.label}
            <Phone slot="icon" className="h-5 w-5" />
          </Button>
        )
      }
    </div>
  </Container>
</section>
