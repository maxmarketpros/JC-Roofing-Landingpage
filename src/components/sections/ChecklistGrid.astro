---
import { ArrowRight, Phone } from "lucide-react";
import Container from "@/components/ui/Container.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Button from "@/components/ui/Button.astro";
import ChecklistItem from "@/components/ui/ChecklistItem.astro";
import { cn } from "@/lib/utils";

interface Props {
  items: readonly string[];
  eyebrow?: string;
  heading?: string;
  subtitle?: string;
  columns?: 2 | 3 | 4;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  bgColor?: "white" | "surface";
  class?: string;
  standalone?: boolean;
}

const {
  items,
  eyebrow,
  heading,
  subtitle,
  columns = 2,
  primaryCta,
  secondaryCta,
  bgColor = "white",
  class: className,
  standalone = false,
} = Astro.props as Props;

const colClasses: Record<number, string> = {
  2: "sm:grid-cols-2",
  3: "sm:grid-cols-2 lg:grid-cols-3",
  4: "sm:grid-cols-2 lg:grid-cols-4",
};
---

{
  standalone ? (
    <section
      class={cn(
        "section-padding",
        bgColor === "surface" && "bg-surface",
        className,
      )}
    >
      <Container>
        {heading && (
          <SectionHeading
            eyebrow={eyebrow}
            heading={heading}
            subtitle={subtitle}
            align="center"
          />
        )}
        <div class={cn("mx-auto max-w-3xl grid gap-x-16 gap-y-4", colClasses[columns])}>
          {items.map((item) => (
            <ChecklistItem text={item} />
          ))}
        </div>
        {(primaryCta || secondaryCta) && (
          <div class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
            {primaryCta && (
              <Button href={primaryCta.href} size="lg">
                {primaryCta.label}
                <ArrowRight slot="icon" className="h-5 w-5" />
              </Button>
            )}
            {secondaryCta && (
              <Button href={secondaryCta.href} variant="outline" size="lg">
                {secondaryCta.label}
                <Phone slot="icon" className="h-5 w-5" />
              </Button>
            )}
          </div>
        )}
      </Container>
    </section>
  ) : (
    <div class={className}>
      {heading && (
        <SectionHeading
          eyebrow={eyebrow}
          heading={heading}
          subtitle={subtitle}
          align="center"
        />
      )}
      <div class={cn("mx-auto max-w-3xl grid gap-x-16 gap-y-4", colClasses[columns])}>
        {items.map((item) => (
          <ChecklistItem text={item} />
        ))}
      </div>
      {(primaryCta || secondaryCta) && (
        <div class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
          {primaryCta && (
            <Button href={primaryCta.href} size="lg">
              {primaryCta.label}
              <ArrowRight slot="icon" className="h-5 w-5" />
            </Button>
          )}
          {secondaryCta && (
            <Button href={secondaryCta.href} variant="outline" size="lg">
              {secondaryCta.label}
              <Phone slot="icon" className="h-5 w-5" />
            </Button>
          )}
        </div>
      )}
    </div>
  )
}
