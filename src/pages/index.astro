  {/* ============ FAQ ============ */}
  <section
    id="faq"
    class="relative scroll-mt-24 border-t border-border bg-surface section-padding"
  >
    <Container>
      <div class="mx-auto max-w-3xl text-center">
        <span
          class="text-xs font-bold uppercase tracking-[0.2em] text-primary-300"
        >
          FAQ
        </span>
        <h2
          class="mt-3 text-balance text-3xl font-bold text-white md:text-5xl"
        >
          Common questions, straight answers.
        </h2>
      </div>

      <div class="mx-auto mt-12 max-w-3xl">
        <div class="overflow-hidden rounded-2xl border border-border bg-background/60 backdrop-blur-sm">
          {
            faqs.map(({ q, a }, i) => (
              <details
                class="group border-b border-border last:border-b-0 [&_summary::-webkit-details-marker]:hidden"
                open={i === 0}
              >
                <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-5 text-left text-base font-semibold text-white transition-colors hover:bg-white/[0.02] md:text-lg">
                  <span>{q}</span>
                  <ChevronDown className="h-5 w-5 shrink-0 text-primary-300 transition-transform duration-300 group-open:rotate-180" />
                </summary>
                <div class="px-6 pb-6 text-sm leading-relaxed text-foreground-light md:text-base">
                  {a}
                </div>
              </details>
            ))
          }
        </div>

        <p class="mt-8 text-center text-sm text-muted">
          Still got a question?{" "}
          <a
            href={`tel:${businessConfig.phoneRaw}`}
            class="font-semibold text-primary-300 underline-offset-4 hover:underline"
          >
            Call {businessConfig.phone}
          </a>
          . We'll pick up.
        </p>
      </div>
    </Container>

    {/* ===== Structured data ===== */}
    {/* WebPage */}
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(webPageSchema)}
    />

    {/* Service (one node per service) */}
    {
      serviceSchemas.map((schema) => (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(schema)}
        />
      ))
    }

    {/* AggregateRating */}
    {
      aggregateRatingSchema && (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(aggregateRatingSchema)}
        />
      )
    }

    {/* Reviews (one per node) */}
    {
      reviewSchemas.map((schema) => (
        <script
          type="application/ld+json"
          is:inline
          set:html={JSON.stringify(schema)}
        />
      ))
    }

    {/* FAQPage */}
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqs.map(({ q, a }) => ({
          "@type": "Question",
          name: q,
          acceptedAnswer: { "@type": "Answer", text: a },
        })),
      })}
    />
  </section>

  {/* ============ CONTACT / FORM ============ */}
  <section id="contact" class="scroll-mt-24 section-padding">
    <Container>
      <div class="mx-auto max-w-3xl text-center">
        <span
          class="text-xs font-bold uppercase tracking-[0.2em] text-primary-300"
        >
          Get a Free Quote
        </span>
        <h2
          class="mt-3 text-balance text-3xl font-bold text-white md:text-5xl"
        >
          Tell us about your roof.
        </h2>
        <p class="mt-5 text-lg text-foreground-light">
          Drop your info below or call us directly. Most inspections get
          scheduled within 24 hours.
        </p>
      </div>

      <div class="mt-12 grid gap-8 lg:grid-cols-5 lg:gap-10">
        {/* Form */}
        <div class="lg:col-span-3">
          <form
            name="quote"
            method="POST"
            action="/thank-you"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="rounded-2xl border border-border bg-surface p-6 shadow-card md:p-8"
          >
            <input type="hidden" name="form-name" value="quote" />
            <p class="hidden">
              <label>
                Don't fill this out if you're human:
                <input name="bot-field" />
              </label>
            </p>

            <div class="grid gap-5 md:grid-cols-2">
              <div>
                <label
                  for="quote-name"
                  class="mb-2 block text-sm font-medium text-foreground-light"
                >
                  Full Name <span class="text-primary-300">*</span>
                </label>
                <input
                  id="quote-name"
                  name="name"
                  type="text"
                  required
                  autocomplete="name"
                  placeholder="Your name"
                  class="w-full rounded-lg border border-border bg-background px-4 py-3 text-base text-white placeholder:text-muted focus:border-primary-400 focus:outline-none focus:ring-2 focus:ring-primary-500/40"
                />
              </div>
              <div>
                <label
                  for="quote-phone"
                  class="mb-2 block text-sm font-medium text-foreground-light"
                >
                  Phone <span class="text-primary-300">*</span>
                </label>
                <input
                  id="quote-phone"
                  name="phone"
                  type="tel"
                  required
                  autocomplete="tel"
                  placeholder="(817) 555-1234"
                  class="w-full rounded-lg border border-border bg-background px-4 py-3 text-base text-white placeholder:text-muted focus:border-primary-400 focus:outline-none focus:ring-2 focus:ring-primary-500/40"
                />
              </div>
            </div>

            <div class="mt-5">
              <label
                for="quote-email"
                class="mb-2 block text-sm font-medium text-foreground-light"
              >
                Email <span class="text-primary-300">*</span>
              </label>
              <input
                id="quote-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder="you@example.com"
                class="w-full rounded-lg border border-border bg-background px-4 py-3 text-base text-white placeholder:text-muted focus:border-primary-400 focus:outline-none focus:ring-2 focus:ring-primary-500/40"
              />
            </div>

            <div class="mt-5">
              <label
                for="quote-details"
                class="mb-2 block text-sm font-medium text-foreground-light"
              >
                Details or Questions
              </label>
              <textarea
                id="quote-details"
                name="details"
                rows="5"
                placeholder="Tell us about your roof. Any leaks, hail damage, or questions you have…"
                class="w-full resize-y rounded-lg border border-border bg-background px-4 py-3 text-base text-white placeholder:text-muted focus:border-primary-400 focus:outline-none focus:ring-2 focus:ring-primary-500/40"
              ></textarea>
            </div>

            <button
              type="submit"
              class="mt-7 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-primary-600 px-7 py-4 text-base font-semibold text-white shadow-glow transition-all hover:-translate-y-0.5 hover:bg-primary-500 sm:w-auto"
            >
              Request My Free Quote
              <ArrowRight className="h-5 w-5" />
            </button>

            <p class="mt-4 text-xs text-muted">
              By submitting, you agree to be contacted about your roofing
              project. We never share your info.
            </p>
          </form>
        </div>

        {/* Contact details */}
        <aside class="lg:col-span-2">
          <div
            class="h-full rounded-2xl border border-border bg-surface p-6 md:p-8"
          >
            <h3 class="text-xl font-bold text-white">Prefer to call?</h3>
            <p class="mt-2 text-sm text-foreground-light">
              The fastest way to get on the schedule. We pick up Mon–Sat, and
              we run 24/7 emergency response for active leaks.
            </p>

            <div class="mt-6 space-y-5">
              <a
                href={`tel:${businessConfig.phoneRaw}`}
                class="flex items-center gap-3 transition-colors hover:text-primary-200"
              >
                <div
                  class="flex h-11 w-11 items-center justify-center rounded-lg bg-primary-600/20 text-primary-300"
                >
                  <Phone className="h-5 w-5" />
                </div>
                <div>
                  <p
                    class="text-xs font-medium uppercase tracking-wider text-muted"
                  >
                    Phone
                  </p>
                  <p class="font-semibold text-white">
                    {businessConfig.phone}
                  </p>
                </div>
              </a>

              <a
                href={`mailto:${businessConfig.email}`}
                class="flex items-center gap-3 transition-colors hover:text-primary-200"
              >
                <div
                  class="flex h-11 w-11 items-center justify-center rounded-lg bg-primary-600/20 text-primary-300"
                >
                  <Mail className="h-5 w-5" />
                </div>
                <div>
                  <p
                    class="text-xs font-medium uppercase tracking-wider text-muted"
                  >
                    Email
                  </p>
                  <p class="font-semibold text-white">
                    {businessConfig.email}
                  </p>
                </div>
              </a>

              <div class="flex items-start gap-3">
                <div
                  class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-primary-600/20 text-primary-300"
                >
                  <MapPin className="h-5 w-5" />
                </div>
                <div>
                  <p
                    class="text-xs font-medium uppercase tracking-wider text-muted"
                  >
                    Office
                  </p>
                  <p class="font-semibold text-white">
                    {businessConfig.address.street}
                  </p>
                  <p class="text-sm text-foreground-light">
                    {businessConfig.address.city},{" "}
                    {businessConfig.address.state} {businessConfig.address.zip}
                  </p>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div
                  class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-primary-600/20 text-primary-300"
                >
                  <Clock className="h-5 w-5" />
                </div>
                <div>
                  <p
                    class="text-xs font-medium uppercase tracking-wider text-muted"
                  >
                    Hours
                  </p>
                  <p class="font-semibold text-white">Mon–Sat: 8 AM – 5 PM</p>
                  <p class="text-sm text-foreground-light">
                    24/7 Emergency Response
                  </p>
                </div>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </Container>
  </section>

  {/* ============ FINAL CTA BANNER ============ */}
  <section class="relative overflow-hidden bg-primary-700">
    <div class="absolute inset-0 bg-grid opacity-20"></div>
    <div
      class="absolute inset-0 bg-gradient-to-r from-primary-800 via-primary-700 to-primary-600"
